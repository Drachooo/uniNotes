% --- DEFINIZIONE DI AMBIENTI DI LAVORO ---
%===========================================
% --- AMBIENTE DEFINIZIONE ---
\newcommand{\definizione}[2]{%
  \vspace{5pt}%
  \begin{tcolorbox}[
    colback=azzurrino!5!white,
    colframe=azzurrino!50!black,
    title=\textbf{Definizione: #1}, % titolo della definizione
    coltitle=white,
    fonttitle=\bfseries,
    arc=2mm, %arrotondamento degli angoli
    boxrule=1pt, %spessore del bordo
    enhanced,
    breakable
  ]
  #2 % testo della definizione
  \end{tcolorbox}
  \vspace{5pt}%
}
