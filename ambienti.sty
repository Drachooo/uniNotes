%===========================================
% --- AMBIENTE CODICE ---
\newtcblisting{codice}[2][]{%
  colback=green!10!white,
  colframe=green!60!black,
  title=\textbf{Codice: #2},
  fonttitle=\bfseries,
  arc=2mm,
  boxrule=1pt,
  enhanced,
  breakable,
  listing only,
  listing options={
    language=#1,
    basicstyle=\ttfamily\footnotesize,
    numbers=left,
    numberstyle=\tiny,
    stepnumber=1,
    numbersep=5pt,
    showstringspaces=false,
    tabsize=2,
    breaklines=true
  }
}
%==========================================
\newtcolorbox{er}[2][]{%
  enhanced, breakable,
  colback=gray!3,
  colframe=blue!50!black,
  fonttitle=\bfseries,
  title={Esercizio E-R: #2},
  before upper={\refstepcounter{erex}},
  sharp corners=south,
  boxrule=0.8pt,
  arc = 2mm
  #1
}
