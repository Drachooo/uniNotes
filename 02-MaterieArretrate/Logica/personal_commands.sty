\RequirePackage{ulem}        % per sottolineature colorate
\RequirePackage{etoolbox}    % per \ifstrempty



% ===== LISTA COMANDI =====
%------comando DEFINIZIONE-------%
\newcommand{\definizione}[2]{%
\vspace{15pt}%
\begin{tcolorbox}[
  colback=cyan!5!white,
  colframe=blue!50!black,
  title=\textbf{Definizione: #1}, % titolo della definizione
  coltitle=white,
  fonttitle=\bfseries,
  arc=3mm,
  boxrule=0.5pt,
  enhanced,
  breakable
]
#2 % testo della definizione
\end{tcolorbox}
\vspace{15pt}%
}
%Funzionamento: \definizione{TITOLO DA SCRIVRE}{TESTO DA SCRIVERE}



%------comando PROPOSIZIONE-------%
\newcommand{\proposizione}[1]{%
\vspace{15pt}%
\begin{tcolorbox}[
  colback=cyan!5!white,
  colframe=blue!50!black,
  title=\textbf{Proposizione}, % titolo della proposizione
  coltitle=white,
  fonttitle=\bfseries,
  arc=3mm,
  boxrule=0.5pt,
  enhanced,
  breakable
]
#1 % testo della proposizione
\end{tcolorbox}
\vspace{15pt}%
}
%Funzionamento: \proposizione{TESTO DA SCRIVERE}

% --- comando PROPOSIZIONE con DIMOSTRAZIONE ---
\newcommand{\Proposizione}[2]{%
  \vspace{5pt}%
  \begin{tcolorbox}[
    colback=cyan!5!white,
    colframe=blue!50!black,
    title=\textbf{Proposizione},
    coltitle=white,
    fonttitle=\bfseries,
    arc=3mm,
    boxrule=0.5pt,
    enhanced,
    breakable
  ]
  #1 % testo della proposizione
  \ifstrempty{#2}{}{%
    \par\vspace{8pt}%
    \textbf{Dimostrazione}#2
  }
  \end{tcolorbox}%
  \vspace{5pt}%
}



